    { "id": "cta_label",      "type": "text",   "label": "Button label", "default": "Get involved" },
    { "id": "cta_url",        "type": "url",    "label": "Button link", "default": "#" },
    { "id": "background",     "type": "select", "label": "Background", "options": ["primary", "accent", "alert_red", "alert_amber"], "default": "primary" },
    { "id": "text_alignment", "type": "select", "label": "Text alignment", "options": ["left", "center", "right"], "default": "center" }
  ]
